# Google OAuth - from https://console.cloud.google.com/
# Enable Google Calendar API, create OAuth 2.0 Web application credentials
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Admin account: this Google account can create events that sync to all connected users
# Use the exact Google account email (e.g. admin@gmail.com)
ADMIN_EMAIL=admin@example.com

NEXT_PUBLIC_APP_URL=http://localhost:3000
